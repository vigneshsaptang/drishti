# =============================================================
# SIGINT Platform — Environment Configuration
# Copy to .env and fill in values before deployment
# =============================================================

# --- Domain & TLS ---
# For production: your actual domain (Caddy auto-provisions HTTPS via Let's Encrypt)
# For local dev: localhost
DOMAIN=localhost
ADMIN_EMAIL=admin@yourdomain.com

# --- Saptang web login (optional) ---
# If SAPTANG_ADMIN_PASSWORD is set, the UI requires sign-in. Leave empty to allow access without a password.
SAPTANG_ADMIN_USER=operator
SAPTANG_ADMIN_PASSWORD=
# Use a long random value in production when login is enabled
SAPTANG_JWT_SECRET=change-me-to-a-long-random-string
SAPTANG_TOKEN_EXP_HOURS=24

# --- MongoDB Connections ---
MONGO_URI_CREDMON=mongodb://user:pass@host:port/?authMechanism=DEFAULT
MONGO_URI_DARKMON=mongodb://user:pass@host:port/?authMechanism=DEFAULT&authSource=admin
MONGO_URI_FTI=mongodb://user:pass@host:port/admin?authSource=admin

# --- Backend ---
BACKEND_PORT=8000
WORKERS=4
LOG_LEVEL=info

# --- Search Defaults ---
MAX_SEARCH_DEPTH=3
MAX_ENTITIES_PER_DEPTH=100
DARKMON_QUERY_TIMEOUT_MS=8000
CREDMON_SOCKET_TIMEOUT_MS=30000

# --- Tor Proxy (for .onion link rendering) ---
TOR_SOCKS_PORT=9050
TOR_HTTP_PORT=8118
